		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/svelte": "^5.3.1",
		"@vite-pwa/sveltekit": "^1.1.0",
		"fake-indexeddb": "^6.2.5",
		"playwright": "^1.58.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.91.1",
		"@sentry/sveltekit": "^10.49.0",
