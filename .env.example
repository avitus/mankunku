# Supabase Configuration
# Get these values from your Supabase project dashboard: https://supabase.com/dashboard

# Your Supabase project URL
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anonymous/public key (safe to expose in client-side code)
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# IMPORTANT: Never expose the service_role key in client-side code.
# The service_role key should only be used in secure server-side environments.
