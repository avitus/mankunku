# Supabase Configuration
# Get these values from your Supabase project dashboard: https://supabase.com/dashboard

# Your Supabase project URL
PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous/public key (safe to expose in client-side code)
PUBLIC_SUPABASE_ANON_KEY=your-public-key

# IMPORTANT: Never expose the service_role key in client-side code.
# The service_role key should only be used in secure server-side environments.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key for the in-app docs assistant (server-only).
# Used by /api/chat to generate responses from Claude. Without this set, the
# chat panel still renders but returns a friendly "not configured" error.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key
