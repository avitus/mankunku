{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Generated by chunk init.",
  "enabledPlugins": {
    "coderabbit@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": ".claude/hooks/fetch-coderabbit-review.sh",
            "timeout": 180,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "cd ${CLAUDE_PROJECT_DIR:-.} \u0026\u0026 npm ci",
            "timeout": 60,
            "type": "command"
          },
          {
            "command": "cd ${CLAUDE_PROJECT_DIR:-.} \u0026\u0026 npm test",
            "timeout": 300,
            "type": "command"
          }
        ],
        "matcher": "Bash(git commit*)"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(chunk:*)"
    ]
  }
}
